---
import type { Career } from '../types'

interface Props {
  career: Career,
  position: 'left' | 'right'
}

const { career, position } = Astro.props

const rootClasses = [
  "bg-accent/5 border border-accent/10 p-4 md:p-6 rounded-2xl hover:border-accent/40 transition-all group",
  { "text-right": position === 'left' }
]

const skillsClasses = [
  "flex flex-wrap gap-2",
  { "justify-end": position === 'left' }
]
---

<div class:list={rootClasses}>
  <span class="font-mono text-xs tracking-widest uppercase text-accent/75">{career.period}</span>

  <h3 class="text-xl font-heading font-bold text-maintext mt-1">{career.role}</h3>
  <p class="text-accent text-sm mb-4">{career.company}</p>

  <p class="text-subtext font-body text-sm leading-relaxed mb-4">{career.description}</p>

  <div class:list={skillsClasses}>
    {career.skills.map(skill => (
      <span class="rounded-md text-[10px] px-2 md:px-4 py-1 bg-accent/5 border border-accent/10 text-accent/80 group-hover:border-accent/40 group-hover:text-accent">
        {skill}
      </span>
    ))}
  </div>
</div>
