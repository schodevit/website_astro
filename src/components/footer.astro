---
import { Icon } from 'astro-icon/components'
import homeData from '../data/home.json'

import type { HomeData } from '../types'

const { siteName } = homeData as HomeData
const currentYear = new Date().getFullYear()
---

<footer class="section-container">
  <div class="container mx-auto">
    <div class="pt-8 border-t border-textrain/10">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-subtext text-sm font-body order-2 md:order-1">
          {siteName} © {currentYear}
        </p>

        <div class="flex items-center flex-wrap justify-center gap-3 text-subtext text-xs font-body order-1 md:order-2">
          <span>Built using</span>

          <div class="flex gap-4">
            <a href="https://astro.build" target="_blank" class="hover:text-accent transition-colors flex items-center gap-1.5 group">
              <Icon name="skill-icons:astro" class="w-4 h-4 group-hover:drop-shadow-[0_0_5px_var(--color-accent)]" />
              <span>Astro</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
