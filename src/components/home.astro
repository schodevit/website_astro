---
import { Image } from 'astro:assets'
import SocialItem from './social-item.astro'
import avatarImg from '../assets/avatar.jpg'

import homeData from '../data/home.json'
import socialsData from '../data/socials.json'

import type { HomeData, Social } from '../types'

interface SocialsData {
  socials: Social[]
}

const { fullName, introHtml, resumeUrl } = homeData as HomeData
const { socials } = socialsData as SocialsData

const URL_REGEX = /^(https?:\/\/|mailto:|tel:)/

const visibleSocials = socials.filter(social => (
  String(social.url).match(URL_REGEX) && social.url !== "#"
))
---

<section id="home" class="slideGroup flex flex-col items-center justify-center section-container md:pt-30 gap-4 min-h-[80vh] text-center">
  <div class="slideUp relative group mb-2">
    <div class="balloon-float size-20 md:size-32 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)]">
      {
        avatarImg && (
          <Image
            src={avatarImg}
            alt={`${fullName} - Senior Ruby on Rails Developer`}
            class="w-full h-full object-cover scale-110"
            loading="eager"
          />
        )
      }
    </div>

    <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-20"/>
  </div>

  <div class="slideUp">
    <p class="text-gray font-body text-lg leading-relaxed">
      Hello, I'm
    </p>
  </div>

  <div class="slideUp px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0">
    <h1 class="text-5xl md:text-7xl font-heading font-bold text-maintext tracking-tight">{fullName}</h1>
    <br />

    <p
      class="text-gray font-body text-lg leading-relaxed"
      set:html={introHtml}
    />
  </div>

  <div class="slideUp mt-8 mb-4">
    <a
      href={resumeUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group relative inline-flex items-center justify-center px-10 py-2 bg-white/5 border border-white/10 rounded-full text-maintext font-body transition-all duration-300
             <!-- /* Mobile: Always active */ -->
             border-accent/50 bg-accent/10 shadow-[0_0_20px_rgba(var(--accent-rgb),0.3)]
             <!-- /* Desktop: Reset and hover */ -->
             md:border-accent/50 md:bg-accent/10 md:shadow-none md:hover:border-accent/50 md:hover:bg-accent/10 md:hover:shadow-[0_0_20px_rgba(var(--accent-rgb),0.3)]
             hover:scale-105"
    >
      <div class="flex flex-col items-center justify-center text-center">
        <span class="tracking-wide text-sm md:text-base font-medium transition-transform duration-300 md:translate-y-2 md:group-hover:translate-y-0">
          View Resume
        </span>

        <span class="text-[10px] text-subtext font-light whitespace-nowrap transition-all duration-300
                     /* Mobile: Always visible */
                     opacity-100 translate-y-0
                     /* Desktop: Hidden until hover */
                     md:opacity-0 md:translate-y-1 md:group-hover:opacity-100 md:group-hover:translate-y-0"
        >
          Downloads PDF file
        </span>
      </div>

      <div class="absolute inset-0 rounded-full blur-md bg-accent/20 -z-10 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-500" />
    </a>
  </div>

  <div class="slideUp flex gap-6 mt-4">
    {visibleSocials.map(social => <SocialItem social={social} /> )}
  </div>
</section>


<style is:global>
  .avatar-container {
    animation: float 5s ease-in-out infinite alternate, wobble 7s ease-in-out infinite alternate;
  }

  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }

  @keyframes floating-balloon {
    0% {
      transform: translate(0, 0) rotate(0deg);
    }
    33% {
      /* Moves up and slightly right */
      transform: translate(3px, -8px) rotate(1deg);
    }
    66% {
      /* Drifts left and stays elevated */
      transform: translate(-3px, -4px) rotate(-1deg);
    }
    100% {
      /* Returns to start */
      transform: translate(0, 0) rotate(0deg);
    }
  }
</style>
