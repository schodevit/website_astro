---
import { Icon } from 'astro-icon/components'

import type { Social } from '../types'

interface Props {
  social: Social
}

const { social } = Astro.props
---

<a
  href={social.url}
  target="_blank"
  class="group relative flex flex-col items-center justify-center transition-all duration-300 hover:scale-110"
>
  <Icon
    name={social.icon}
    class="size-8 text-maintext group-hover:text-accent transition-colors duration-300"
  />

  <span class="absolute -bottom-6 scale-0 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-300 text-xs text-accent font-body">
    {social.name}
  </span>
</a>
