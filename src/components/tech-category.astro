---
import TechSkill from './tech-skill.astro'

import type { Category } from '../types'

interface Props {
  category: Category
}

const { category } = Astro.props
---

<div class="space-y-3">
  <h3 class="text-maintext font-body text-[11px] uppercase tracking-[0.4em] ml-1">
    {category.title}
  </h3>

  <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-5 xl:grid-cols-6 2xl:grid-cols-7 gap-5 sm:gap-8">
    {category.skills.map(skill => <TechSkill skill={skill} />)}
  </div>
</div>
