---
import TechCategory from './tech-category.astro'
import TechRate from './tech-rate.astro'

import techData from '../data/tech.json'

import type { Category, Rate } from '../types'

interface Data {
  categories: Category[]
}

const { categories } = techData as Data

const rates: Rate[] = [
  { label: "Expert", level: 3 },
  { label: "Proficient", level: 2 },
  { label: "Beginner", level: 1 }
]
---

<section id="tech" class="slideGroup section-container overflow-hidden">
  <div class="container mx-auto">
    <div class="slideUp flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
          <span class="text-accent">/</span> Tech Stack
        </h2>

        <p class="text-subtext font-body text-sm max-w-md">
          Breakdown of my technical skills, categorized by domain and proficiency
        </p>
      </div>

      <div class="flex flex-wrap gap-4 p-3 rounded-xl bg-accent/5 border border-accent/10 backdrop-blur-sm">
        {rates.map((rate, index) => <TechRate rate={rate} index={index} />)}
      </div>
    </div>

    <div class="space-y-10">
      {categories.map(category => <TechCategory category={category} /> )}
    </div>
  </div>
</section>
