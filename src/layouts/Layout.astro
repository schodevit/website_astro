---
import BackToTop from '../components/back-to-top.astro'
import Matrix from "../components/matrix.astro"

import { SITE_CONFIG } from '../config'
import '../styles/global.css'

interface Props {
  title: string
}

const { title } = Astro.props

const baseTheme = SITE_CONFIG.baseTheme
const defaultTheme = `${baseTheme}-dark`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/png" href="/favicon.ico" />
    <title>{title}</title>

    <!-- Initialize theme -->
    <script is:inline define:vars={{ baseTheme, defaultTheme }}>
      const theme = localStorage.getItem('theme') ?? defaultTheme

      document.documentElement.setAttribute('data-theme', theme)
      localStorage.setItem('theme', theme)
    </script>
  </head>

  <body class="bg-container relative min-h-screen overflow-x-hidden antialiased">
    <Matrix />

    <main class="px-2 sm:px-12 md:px-14 lg:px-28 max-w-360 mx-auto relative z-0">
      <slot />
    </main>

    <BackToTop />
  </body>
</html>
