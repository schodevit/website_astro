---
import Layout from '../layouts/Layout.astro'

import Nav from '../components/nav.astro'
import Home from '../components/home.astro'
import Tech from '../components/tech.astro'
import Contact from '../components/contact.astro'
import Career from '../components/career.astro'
import Footer from '../components/footer.astro'
import MobileNav from '../components/mobile-nav.astro'

import homeData from '../data/home.json'

interface HomeData {
  siteTitle: string
}

const { siteTitle } = homeData as HomeData
---

<Layout siteTitle={siteTitle}>
  <Nav />
	<Home />
	<Career />
	<Tech />
	<Contact />
  <Footer />
  <MobileNav />
</Layout>

<script>
import { gsap } from 'gsap'
import { ScrollTrigger } from 'gsap/ScrollTrigger'

gsap.registerPlugin(ScrollTrigger)

document.querySelectorAll(".slideGroup").forEach((group) => {
  const items = group.querySelectorAll(".slideUp")

  gsap.from(items, {
    opacity: 0,
    y: 40,
    duration: 0.8,
    stagger: 0.1,
    ease: "power2.out",

    scrollTrigger: {
      trigger: group,
      start: "top 80%",
      toggleActions: "play none none none",
      once: true,
    }
  })
})

window.addEventListener("load", () => {
  ScrollTrigger.refresh()
})
</script>
